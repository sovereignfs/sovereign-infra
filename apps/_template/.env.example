# apps/_template/.env.example
# Copy to .env on the VPS. This file is committed. The actual .env is NOT.
# Encrypt with:  ./scripts/encrypt-env.sh <appname>

# ── Secrets ───────────────────────────────────────────────────────────────────
SOME_SECRET=

# ── Host port (Caddy proxies this) ────────────────────────────────────────────
# Pick the next free port from docs/ports.md and add a row there.
APP_PORT=5000

# ── Image version ─────────────────────────────────────────────────────────────
# APP_VERSION=v1.0.0
