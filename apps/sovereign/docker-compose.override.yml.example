# apps/sovereign/docker-compose.override.yml.example
#
# Workaround for env vars that are consumed by the Sovereign code but missing
# from the upstream docker-compose.prod.yml environment: blocks. Without these,
# the vars have no effect even when set in .env.
#
# Usage:
#   cp apps/sovereign/docker-compose.override.yml.example \
#      apps/sovereign/docker-compose.override.yml
#   git add apps/sovereign/docker-compose.override.yml
#   git commit -m "config: enable compose override for missing env vars"
#
# The CI deploy job automatically copies this file to /opt/apps/sovereign/ on
# the VPS when it is present in the repo. It is merged into the compose stack
# alongside docker-compose.prod.yml and docker-compose.postgres.yml.
#
# Once sovereignfs/sovereign adds these to its own compose file, this override
# can be removed.
#
# Fixed upstream as of v0.19.3 (no longer needed if you're deploying that
# version or later): AUTH_WEBAUTHN_RP_ID, AUTH_WEBAUTHN_RP_NAME,
# AUTH_WEBAUTHN_ORIGIN, LOG_LEVEL, VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY,
# VAPID_CONTACT, NOTIFICATION_TRANSPORT, REDIS_URL. Removed from this example
# below — if you already have an active override with these, it's now
# redundant (harmless) and safe to trim, but not urgent.

services:
  runtime:
    environment:
      # Plugin secret vault key (sdk.secrets) — still missing from upstream
      # compose as of v0.19.3. Fails closed with no default: any plugin that
      # stores/reads a secret (e.g. Plainwrite's GitHub PAT flow) breaks with
      # "SOVEREIGN_VAULT_KEY is required before sdk.secrets can store or read
      # secret values." at first use, not at container startup. Must also be
      # set in .env (generate with `openssl rand -base64 32`) — this override
      # alone does nothing if the value itself was never set.
      SOVEREIGN_VAULT_KEY: ${SOVEREIGN_VAULT_KEY}
