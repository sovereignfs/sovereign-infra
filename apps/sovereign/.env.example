# Sovereign environment configuration.
#
# Upstream section auto-synced from sovereignfs/sovereign/.env.example
# via scripts/generate-env.js — do not edit above the separator line.
# Deployment-specific overrides live below the separator.
#
# To render apps/<app>/.env from this template plus your own secrets,
# fill in env.yml (copy from env.example.yml) and run:
#   node scripts/generate-env.js <app>

# Sovereign environment configuration. Copy to .env and adjust.
#
# A single .env at the repo root configures the whole monorepo. Each Next app
# loads it via `loadEnvConfig(repoRoot)` in its next.config.ts — no per-app
# .env files needed. (More variables land with the runtime/deploy tasks.)

# --- Auth server (apps/auth) ---
# AUTH_SECRET has no default — the auth server refuses to start without it.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=
# When true, registration requires a valid invite (the first user is exempt).
AUTH_INVITE_ONLY=false
# Auth identity database — the auth server's own, separate from DATABASE_URL.
# Relative paths resolve against the repo root, so the default lands in the
# root-level data/ directory alongside the platform DB. Override only if needed.
# AUTH_DATABASE_URL=file:./data/auth.db
# Public base URL of the auth server. Set to your domain in production
# (e.g. https://auth.example.com, or https://example.com if auth and runtime
# share a domain). Used by better-auth for callback construction and CSRF origin
# validation. Leave unset for local dev — defaults to http://localhost:${AUTH_PORT:-3001}.
# !! REQUIRED for production — see NEXT_PUBLIC_RUNTIME_URL note below !!
# AUTH_BASE_URL=http://localhost:3001
# Comma-separated list of origins trusted for server-to-server CSRF checks, in
# addition to AUTH_BASE_URL. Set this to the internal Docker service address
# (http://auth:3001) when AUTH_BASE_URL is your public domain, so runtime→auth
# API calls (avatar upload, password change, etc.) are accepted. Not needed for
# native dev (both use localhost:${AUTH_PORT:-3001}).
# !! REQUIRED for production with Docker Compose !!
# AUTH_TRUSTED_ORIGINS=http://auth:3001
# Cookie domain for cross-subdomain session sharing. Required when auth and
# runtime are on different subdomains (e.g. auth.example.com + example.com).
# Set to the shared parent domain with a leading dot: .example.com
# Leave unset for local dev (both on localhost).
# !! REQUIRED for production split-subdomain deployments !!
# AUTH_COOKIE_DOMAIN=.example.com
# WebAuthn / passkeys (RFC 0012). These only matter if you enable passkeys.
# The defaults work for localhost development. For production, set them to
# your actual domain and origins.
# AUTH_WEBAUTHN_RP_ID=localhost
# AUTH_WEBAUTHN_RP_NAME=Sovereign
# Comma-separated list of allowed WebAuthn origins. Must include the runtime
# origin because passkey sign-in and management go through the runtime proxy.
# Keep the auth server public origin included while compatibility routes remain
# exposed. Defaults to the localhost ports automatically; in production set to e.g.:
#   AUTH_WEBAUTHN_ORIGIN=https://example.com,https://auth.example.com
# AUTH_WEBAUTHN_ORIGIN=http://localhost:3000,http://localhost:3001

# --- Runtime (runtime/) ---
# Where the runtime reaches the auth server (server-to-server, e.g. /api/verify)
# and the browser-facing runtime URL used in auth emails/compatibility pages.
#
# Leave both UNSET for local use: native `pnpm dev` derives localhost URLs from
# RUNTIME_PORT / AUTH_PORT, and the Compose files inject the right values per
# environment (dev → :3000/:3001, prod → :4000/:4001 on the host). Setting them
# here would override those per-environment defaults for ALL environments at once.
#
# !! REQUIRED for production (VPS / server deployments) !!
# Without these, post-login redirects go to localhost:* which the remote browser
# cannot reach — causing a login loop.
#
# Set AUTH_BASE_URL (in the Auth section above) to the public-facing auth URL,
# then set NEXT_PUBLIC_RUNTIME_URL here to the public-facing runtime URL.
# Example with IP:     NEXT_PUBLIC_RUNTIME_URL=http://203.0.113.10:4000
# Example with domain: NEXT_PUBLIC_RUNTIME_URL=https://example.com
#
# SOVEREIGN_AUTH_URL stays the internal Docker address (set by Compose automatically).
# SOVEREIGN_AUTH_URL=http://localhost:3001
# NEXT_PUBLIC_RUNTIME_URL=http://localhost:3000
# Where the auth server reaches the runtime for server-to-server calls (e.g.
# recording email-delivery-failure activity log entries). The reverse of
# SOVEREIGN_AUTH_URL. Docker Compose sets it to the internal service name
# (http://runtime:3000) automatically — only set it for non-Docker/native runs
# where the auth server needs to reach a non-default runtime port.
# SOVEREIGN_RUNTIME_URL=http://localhost:3000
# Shared secret for runtime→auth admin API calls (Console user management).
# No default — the auth server and runtime both refuse to start without it.
# Generate one with:  openssl rand -base64 32
SOVEREIGN_ADMIN_KEY=
# Secret for local session verification (SRS AUTH-05). The runtime verifies the
# auth server's signed session cookie offline using this secret — no /api/verify
# round-trip per request — falling back to /api/verify when absent. It MUST equal
# the auth server's signing secret, so it defaults to AUTH_SECRET above; set it
# only if you deliberately run a distinct value.
# SOVEREIGN_AUTH_SECRET=

# Platform-managed plugin secret vault key (RFC 0043). Required before plugins
# can create/read runtime secrets through sdk.secrets. No default; generate with:
#   openssl rand -base64 32
# Required in practice for the bundled Plainwrite plugin's GitHub PAT flow —
# without it, connecting a site fails at "Connect using a token" with:
#   SOVEREIGN_VAULT_KEY is required before sdk.secrets can store or read secret values.
# SOVEREIGN_VAULT_KEY=

# --- Diagnostics & dev-mode (RFC 0020) ---
# Structured logging level. Logs go to stdout/stderr only — never egresses
# (see docs/security.md). Values: error | warn (default) | info | debug.
# LOG_LEVEL=warn

# Production dev-mode: lets operators exercise features on a live instance
# against a seeded mock database without touching real user data (RFC 0020).
# Off by default — the feature does not exist unless explicitly enabled.
# SOVEREIGN_DEV_MODE_ENABLED=true
#
# Secret that callers must supply in X-Sovereign-Dev-Mode-Secret to activate
# dev-mode on a request. Falls back to SOVEREIGN_ADMIN_KEY when unset. Must
# not have a default — no-secrets-with-defaults rule.
# SOVEREIGN_DEV_MODE_SECRET=
#
# URL of the mock database populated by `sv seed`. Must be a separate file
# from DATABASE_URL — dev-mode requests read/write only this DB.
# SOVEREIGN_DEV_DATABASE_URL=file:./data/sovereign-dev.db

# --- Database ---
# SQLite by default (zero-config). Relative paths resolve against the repo
# root — all SQLite files land in the root-level data/ directory.
DATABASE_URL=file:./data/sovereign.db
DB_DIALECT=sqlite

# PostgreSQL: point DATABASE_URL + AUTH_DATABASE_URL at a postgres:// URL and set
# DB_DIALECT=postgres. With the Docker stack, layer docker-compose.postgres.yml
# over docker-compose.prod.yml (it provisions a postgres service and wires both
# apps to it) — then only POSTGRES_PASSWORD below is required. See
# docs/self-hosting.md.
# POSTGRES_USER=sovereign
# POSTGRES_PASSWORD=
# POSTGRES_DB=sovereign
# Path to a CA PEM file for Postgres TLS certificate verification. Only used
# when DATABASE_URL / AUTH_DATABASE_URL includes sslmode=verify-full. Uses the
# standard libpq convention (same as the PGSSLROOTCERT env var in psql/pg_dump).
# PGSSLROOTCERT=/path/to/ca.pem

# --- Plugin file storage (RFC 0044) ---
# Conservative default quotas for sdk.storage.put() — object and per-plugin
# totals in bytes. sdk.storage.put() throws once either would be exceeded.
# Defaults: 25 MiB per object, 500 MiB per plugin.
# SOVEREIGN_STORAGE_MAX_OBJECT_BYTES=26214400
# SOVEREIGN_STORAGE_MAX_PLUGIN_BYTES=524288000

# --- Email (SMTP) ---
# In dev (NODE_ENV != production) the mailer automatically falls back to Mailpit
# on localhost:1025 when SMTP_HOST is unset — no config needed for local dev.
# For Docker Compose dev set SMTP_HOST=mailpit (the service name).
# In production, with SMTP_HOST unset the mailer is a graceful no-op.
#   Docker (app in Compose): SMTP_HOST=mailpit
#   Native / pnpm dev:       (unset — auto-falls back to localhost:1025)
# SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sovereign <noreply@sovereign.local>

# Mailpit host-port overrides (optional; defaults 1025 / 8025)
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025

# --- Docker Compose ---
# Host port the runtime is mapped to. Native `pnpm dev` also uses this port.
# Default in dev (docker-compose.yml):      3000
# Default in prod (docker-compose.prod.yml): 4000
# RUNTIME_PORT=3000
# Host port the auth server is mapped to. Native `pnpm dev` also uses this port.
# Default in dev (docker-compose.yml):      3001
# Default in prod (docker-compose.prod.yml): 4001
# AUTH_PORT=3001

# Browser-facing URL for auth server compatibility routes. In Docker Compose the
# runtime sets SOVEREIGN_AUTH_URL to the internal service name (http://auth:3001),
# which the browser cannot resolve. SOVEREIGN_AUTH_PUBLIC_URL is the host-reachable
# address for direct auth-server browser access; server-side API calls continue to use
# SOVEREIGN_AUTH_URL. Not needed for native dev (defaults to localhost:${AUTH_PORT:-3001}).
# SOVEREIGN_AUTH_PUBLIC_URL=http://localhost:3001

# Note: SOVEREIGN_AUTH_URL above is for native dev (localhost:${AUTH_PORT:-3001}).
# When using Docker Compose, the runtime container overrides this to
# http://auth:3001 (internal Docker network) automatically — do not change
# SOVEREIGN_AUTH_URL for Docker use.

# ── Web Push / VAPID (RFC 0016) ───────────────────────────────────────────────
# Optional. When both keys are set, Sovereign sends background push
# notifications to subscribed browser devices. Leave unset to disable push
# (the in-app bell is the fallback — the app works without push configured).
#
# Generate a VAPID key pair once per deployment with:
#   npx web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY=<base64url public key>
# VAPID_PRIVATE_KEY=<base64url private key>
# Contact email or URL used in the VAPID Authorization header (required by spec).
# VAPID_CONTACT=mailto:admin@example.com

# ── Notification transport (RFC 0034) ────────────────────────────────────────
# Controls how the bell receives notifications. Default is polling (no extra infra).
# Set to 'sse' for instant in-process delivery (single-process deployments).
# Set to 'redis' for instant cross-process delivery (multi-process / clustered).
# REDIS_URL is required when NOTIFICATION_TRANSPORT=redis.
#
# NOTIFICATION_TRANSPORT=polling
# REDIS_URL=redis://localhost:6379
# Optional: heartbeat interval in milliseconds sent on the SSE stream to prevent
# proxy idle-timeout disconnections (default: 25000).
# NOTIFICATION_HEARTBEAT_INTERVAL=25000

# ── Plugin scheduler (RFC 0046 Phase 1) ──────────────────────────────────────
# Optional kill-switch. Set to 1 (or true) to stop the runtime from invoking
# plugin-declared background schedules (manifest `schedules`) — e.g. while
# debugging a misbehaving plugin job. Unset = scheduler runs (the default).
# SOVEREIGN_SCHEDULER_DISABLED=1

# ── Instance identity (RFC 0027 / RFC 0032) ────────────────────────────────────
# Optional. When set, these values are the baseline for the instance.
# Per-instance overrides can be managed in Console → Settings → Instance identity.
# All INSTANCE_* vars are optional — Sovereign defaults apply when unset.
#
# INSTANCE_NAME=Sovereign
# INSTANCE_PRIMARY_COLOR=#000000
# INSTANCE_LOGO=https://example.com/logo.png
# INSTANCE_LOGO_DARK=https://example.com/logo-dark.png
# INSTANCE_FAVICON=https://example.com/favicon.ico
# INSTANCE_EMAIL_FROM_NAME=Sovereign
# INSTANCE_EMAIL_LOGO=https://example.com/logo-email.png

# ── Example plugins (RFC 0017) ─────────────────────────────────────────────────
# The bundled example/demo apps are baked into the image but hidden by default:
# their routes 404 and they never appear in the launcher. Set to 1/true/yes/on to
# show them. An admin can still enable/disable each one (or all) in
# Console → Plugins regardless of this default.
#
# SOVEREIGN_EXAMPLES_ENABLED=1

# ── Development plugins ─────────────────────────────────────────────────────────
# Plugins flagged `development: true` in their manifest (not yet production-
# ready) are shown by default, same as any other plugin — just sorted last in
# the sidebar/launcher with an "in development" badge. Set to 1/true/yes/on to
# hide them completely instead: their routes 404 and they never appear in the
# sidebar, launcher, or admin's launcher/sidebar preview. Unlike
# SOVEREIGN_EXAMPLES_ENABLED, this has no per-plugin override and no Console
# toggle — it's a hard, deploy-time gate for pinning an instance to
# production-ready plugins only.
#
# SOVEREIGN_HIDE_DEVELOPMENT_PLUGINS=1

# ══ deployment overrides ═════════════════════════════════════════════════════
# Everything below is specific to this deployment and is NOT in the sovereign
# repo's .env.example. Run scripts/fetch-env-example.sh to refresh the upstream
# section above without touching this block.

# ── Compose file stacking ─────────────────────────────────────────────────────
# Tells docker compose to always merge both files (base + postgres overlay).
# This means plain `docker compose up/pull/logs` works without -f flags.
COMPOSE_FILE=docker-compose.prod.yml:docker-compose.postgres.yml

# Currently deployed sovereign version. CI overwrites this on each deploy.
# Required — without it docker compose tries to build images locally.
SOVEREIGN_VERSION=0.9.10

# ── Postgres (required by docker-compose.postgres.yml) ────────────────────────
# DATABASE_URL and AUTH_DATABASE_URL are constructed from these by the postgres
# overlay — do not set them directly when using Postgres.
DB_DIALECT=postgres
POSTGRES_PASSWORD=
POSTGRES_USER=sovereign
POSTGRES_DB=sovereign

# ── Public URLs ───────────────────────────────────────────────────────────────
# The runtime URL is passed at runtime — it is only used in server-side code and
# auth redirect callbacks, not baked into client bundles.
NEXT_PUBLIC_RUNTIME_URL=https://YOUR_RUNTIME_DOMAIN
AUTH_BASE_URL=https://YOUR_AUTH_DOMAIN

# Browser-reachable auth URL. The runtime middleware redirects to this for login.
# Without it, redirects go to the internal Docker URL (http://auth:3001) which
# browsers cannot resolve, silently dropping the session after login.
SOVEREIGN_AUTH_PUBLIC_URL=https://YOUR_AUTH_DOMAIN

# Internal origin trusted for server-to-server CSRF checks (runtime → auth).
AUTH_TRUSTED_ORIGINS=http://auth:3001

# Shared parent domain for cross-subdomain session cookies. Required because
# auth (YOUR_AUTH_DOMAIN) and runtime (YOUR_RUNTIME_DOMAIN) are on different
# subdomains — without this the runtime never receives the session cookie and
# every login silently redirects back to the login page.
AUTH_COOKIE_DOMAIN=.YOUR_ROOT_DOMAIN

# ── Host ports ────────────────────────────────────────────────────────────────
RUNTIME_PORT=4000
AUTH_PORT=4001

# ── WebAuthn / passkeys ───────────────────────────────────────────────────────
# RP_ID must be the bare registrable domain. Changing this invalidates existing passkeys.
AUTH_WEBAUTHN_RP_ID=YOUR_ROOT_DOMAIN
AUTH_WEBAUTHN_RP_NAME=Sovereign
AUTH_WEBAUTHN_ORIGIN=https://YOUR_RUNTIME_DOMAIN,https://YOUR_AUTH_DOMAIN

# ── Backups ───────────────────────────────────────────────────────────────────
# Fine-grained PAT with Contents read+write on your backup repo.
BACKUP_GITHUB_TOKEN=
# GitHub repo for encrypted backups (format: owner/repo, e.g. myorg/sovereign-backups).
BACKUP_GITHUB_REPO=YOUR_ORG/YOUR_BACKUP_REPO
# Your age public key (age1...). Used to encrypt backups before they leave the VPS.
AGE_PUBLIC_KEY=
